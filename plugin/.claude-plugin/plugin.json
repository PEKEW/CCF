{
  "name": "ccfl-feishu-session",
  "description": "Feishu-managed Claude Code sessions: cockpit/contract/handoff docs, deterministic sync, risk policy, and MCP doc-authoring tools backed by the ccfl binary.",
  "version": "1.0.0",
  "hooks": {
    "SessionStart": [
      { "hooks": [ { "type": "command", "command": "ccfl hook session-start" } ] }
    ],
    "UserPromptSubmit": [
      { "hooks": [ { "type": "command", "command": "ccfl hook user-prompt-submit" } ] }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|Bash",
        "hooks": [ { "type": "command", "command": "ccfl hook pre-tool-use" } ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [ { "type": "command", "command": "ccfl hook post-tool-use" } ]
      }
    ],
    "Stop": [
      { "hooks": [ { "type": "command", "command": "ccfl hook stop" } ] }
    ],
    "PreCompact": [
      { "hooks": [ { "type": "command", "command": "ccfl hook pre-compact" } ] }
    ],
    "PostCompact": [
      { "hooks": [ { "type": "command", "command": "ccfl hook post-compact" } ] }
    ],
    "SessionEnd": [
      { "hooks": [ { "type": "command", "command": "ccfl hook session-end" } ] }
    ]
  },
  "mcpServers": {
    "ccfl": {
      "type": "stdio",
      "command": "ccfl",
      "args": ["mcp"]
    }
  }
}
